    "@cult-ui": "https://cult-ui.com/r/{name}.json",
    "@kibo-ui": "https://kibo-ui.com/r/{name}.json",
    "@reui-ui": "https://reui.io/r/{name}.json",
    "@shadcn-for": "https://www.shadcn-form.com/r/{name}.json",
    "@reactbits": "https://reactbits.dev/r/{name}.json"
  }
