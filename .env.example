# App Configuration
VITE_APP_TITLE="Horizon Tech"

# API Configuration
VITE_API_URL="http://localhost:8000/api"

# Server Configuration (for SSR/SSG builds)
SERVER_URL="http://localhost:8000"

# i18n — required Azure Blob CDN for translation files
#VITE_LOCALES_CDN="https://htstorageprod.blob.core.windows.net/locales"

# OAuth (optional — only needed for social login)
VITE_MICROSOFT_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# Feature flags (set to "true" to enable)
VITE_FEATURE_CASE_STUDIES=""
VITE_FEATURE_TECHNICAL_RESOURCES=""

# Azure (used by scripts/translate & upload — not needed for dev server)
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_KEY=""
AZURE_TRANSLATOR_KEY=""
AZURE_TRANSLATOR_REGION="northeurope"
